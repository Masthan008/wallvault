rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: is the user logged in?
    function isLoggedIn() {
      return request.auth != null;
    }

    // Helper: does the user match the document userId?
    function isOwner(userId) {
      return isLoggedIn() && request.auth.uid == userId;
    }

    // Helper: is the user an approved creator?
    function isCreator() {
      return isLoggedIn() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isCreator == true;
    }

    // Helper: is the user an admin?
    function isAdmin() {
      return isLoggedIn() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // ── USERS COLLECTION ────────────────────────────────────
    match /users/{userId} {
      allow read: if isLoggedIn();
      allow create, update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // ── CREATORS COLLECTION ─────────────────────────────────
    match /creators/{creatorId} {
      allow read: if isLoggedIn();
      allow create: if isLoggedIn() && isOwner(creatorId);
      allow update: if isOwner(creatorId) || isAdmin();
      allow delete: if isAdmin();
    }

    // ── WALLPAPERS COLLECTION ───────────────────────────────
    match /wallpapers/{wallpaperId} {
      allow read: if true; // Public access for browsing
      allow create: if isCreator();
      allow update: if isLoggedIn() && 
        (resource.data.creatorId == request.auth.uid || isAdmin());
      allow delete: if isLoggedIn() && 
        (resource.data.creatorId == request.auth.uid || isAdmin());
    }

    // ── TRANSACTIONS COLLECTION ──────────────────────────────
    match /transactions/{transactionId} {
      allow read: if isLoggedIn() && 
        (resource.data.userId == request.auth.uid || resource.data.creatorId == request.auth.uid || isAdmin());
      allow write: if isAdmin(); // Only Firebase Cloud Functions can process payments/payouts
    }

    // ── PAYOUTS COLLECTION ──────────────────────────────────
    match /payouts/{payoutId} {
      allow read: if isLoggedIn() && 
        (resource.data.creatorId == request.auth.uid || isAdmin());
      allow write: if isAdmin(); // Managed by cloud functions
    }

    // ── NOTIFICATIONS COLLECTION ────────────────────────────
    match /notifications/{notificationId} {
      allow read: if isLoggedIn() && resource.data.userId == request.auth.uid;
      allow write: if isAdmin();
    }

    // ── REPORTS COLLECTION ──────────────────────────────────
    match /reports/{reportId} {
      allow read: if isAdmin();
      allow create: if isLoggedIn();
      allow update, delete: if isAdmin();
    }

    // ── ADMIN SYSTEM COLLECTION ─────────────────────────────
    match /admin/{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
